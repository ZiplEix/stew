<goscript client>
    import "stew/data"
    import "stew/nav"

    wasmId := data.Params["id"]
    currentUrl := nav.URL
    
    // Test navigation
    handleToGuide := func() {
        nav.To("/guide")
    }
    
    // We must use the variables to avoid compiler errors if bindings fail to generate
    _ = wasmId
    _ = handleToGuide
    _ = currentUrl
</goscript>

<div class="p-10">
    <h1 class="text-2xl font-bold font-sans text-stone-800">Test SDK Navigation</h1>
    <p class="mt-4">ID actuel : <span class="font-mono text-amber-600" bind:content={{wasmId}}>...</span></p>
    <p class="mt-2 text-sm text-stone-500">URL détectée par nav : <code bind:content={{nav.URL}}>...</code></p>
    
    <div class="mt-8 flex gap-4">
        <button on:click={{ nav.To("/guide") }} class="px-6 py-2 bg-stone-800 text-white rounded-full font-bold hover:bg-stone-700 transition">
            Vers Guide (Morph)
        </button>
        <button on:click={{ nav.StandardTo("/guide") }} class="px-6 py-2 border border-stone-300 text-stone-600 rounded-full font-bold hover:bg-stone-50 transition">
            Vers Guide (Standard)
        </button>
        <button on:click={{ nav.Back() }} class="px-6 py-2 bg-amber-500 text-white rounded-full font-bold hover:bg-amber-600 transition">
            Retour
        </button>
    </div>
</div>
