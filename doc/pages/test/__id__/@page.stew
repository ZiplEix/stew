<goscript client>
    import "stew/data"
    import "stew/nav"

    wasmId := data.Params["id"]
    
    // Test navigation
    handleToGuide := func() {
        nav.To("/guide")
    }
    
    // We must use the variables to avoid compiler errors if bindings fail to generate
    _ = wasmId
    _ = handleToGuide
</goscript>

<div class="p-10">
    <h1 class="text-2xl font-bold font-sans text-stone-800">Test SDK Navigation</h1>
    <p class="mt-4">ID actuel : <span class="font-mono text-amber-600" bind:content={{wasmId}}>...</span></p>
    
    <div class="mt-8">
        <button on:click={{ func() { nav.To("/guide") } }} class="px-6 py-2 bg-stone-800 text-white rounded-full font-bold hover:bg-stone-700 transition">
            Retour au Guide (nav.To)
        </button>
    </div>
</div>
