<goscript client>
    import "stew/data"
    import "stew/io"

    // 'data' est injectée via stew/data
    wasmId := data.Params["id"] + " (via stew/data)"

    // Utilisation d'une fonction nommée pour le binding
    handleTest := func() {
        if confirm("Veux-tu changer l'ID ?") {
            newId := prompt("Nouvel ID :")
            if newId != "" {
                wasmId = newId + " (modifié)"
                alert("ID mis à jour !")
            }
        }
    }
</goscript>

<div class="p-12 space-y-12">
    <header class="space-y-4">
        <a href="/guide/routing" class="text-indigo-600 font-mono text-sm shadow-sm bg-white px-3 py-1 rounded-full border border-indigo-100 hover:bg-indigo-50 transition inline-block">
            ← Paramètres dynamiques de route
        </a>
        <h1 class="text-6xl font-black tracking-tighter text-stone-900">
            Route : <span class="bg-indigo-100 px-4 rounded-2xl">/test/{{ data.Params["id"] }}</span>
        </h1>
    </header>

    <div class="grid md:grid-cols-2 gap-8">
        <!-- Rendu Serveur (SSR) -->
        <div class="bg-stone-50 border-2 border-stone-200 rounded-3xl p-8 shadow-sm">
            <p class="text-stone-500 font-medium mb-2 uppercase tracking-widest text-xs">Côté Serveur (SSR) :</p>
            <h2 class="text-4xl font-black text-stone-800">
                ID: {{ data.Params["id"] }}
            </h2>
        </div>

        <!-- Rendu Client (Wasm) -->
        <div class="bg-indigo-50 border-2 border-indigo-200 rounded-3xl p-8 shadow-xl">
            <p class="text-indigo-600 font-medium mb-2 uppercase tracking-widest text-xs">Côté Client (Wasm) :</p>
            <div class="flex gap-4 items-center">
                <div class="px-5 py-2 bg-indigo-600 text-white rounded-full font-bold shadow-lg shadow-indigo-200">
                    ID: <span bind:content={{ wasmId }}>Chargement...</span>
                </div>
                <button on:click={{ handleTest() }} class="px-5 py-2 bg-stone-100 hover:bg-stone-200 text-stone-700 rounded-full font-bold transition">
                    Tester stew/io
                </button>
            </div>
        </div>
    </div>

    <div class="bg-stone-900 rounded-2xl p-6 text-stone-300 font-mono text-sm">
        <p class="mb-4 text-stone-500">// Roadmap & Status :</p>
        <ul class="space-y-2">
            <li>- [x] Framework: Update `PageData` JSON tags (`Request`, `Query`)</li>
            <li>- [x] SDK: Create `sdk/wasm/io` package</li>
            <li>- [x] SDK: Implement `Console`, `Alert`, `Prompt`, `Confirm`</li>
            <li>- [x] Compiler: Implement `stew/io` rewrite and helper injection</li>
            <li>- [x] Documentation: Add `stew/io` to Wasm SDK guide</li>
            <li>- [x] Verification: Test `import "stew/io"` on test page</li>
            <li>- [x] Cleanup: Ensure all virtual imports follow the same pattern</li>
            <li>- [x] Verification: Test `import "stew/data"` on `/test/__id__` page</li>
            <li>- [x] Verification: Confirm binary size vs performance tradeoff</li>
        </ul>
    </div>

    <footer class="pt-8">
        <a href="/" class="text-amber-600 font-bold hover:underline">← Retour à l'accueil</a>
    </footer>
</div>
