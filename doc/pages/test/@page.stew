<goscript client>
    import "stew/state"
    import "stew/storage"

    // Persistent name via LocalStorage
    userName := state.New("Visiteur")
    storage.Local.Bind(userName, "user_name")

    // Session-only counter
    sessionVal := storage.Session.Get("session_counter")
    if sessionVal == "" {
        sessionVal = "0"
    }
    sessionData := state.New(sessionVal)
    
    incrementSession := func() {
        val := sessionData.Get()
        // Simple demo logic
        if val == "0" { 
            val = "1" 
        } else if val == "1" { 
            val = "2" 
        } else { 
            val = "Many" 
        }
        sessionData.Set(val)
        storage.Session.Set("session_counter", val)
    }

    clearAll := func() {
        storage.Local.Clear()
        storage.Session.Clear()
        userName.Set("Nettoyé")
        sessionData.Set("0")
    }
</goscript>

<div class="p-10 max-w-2xl mx-auto">
    <h1 class="text-3xl font-extrabold text-stone-800">Test Storage SDK</h1>
    
    <div class="mt-8 p-6 bg-white rounded-2xl shadow-sm border border-stone-100">
        <h2 class="text-lg font-bold text-stone-700">LocalStorage (Persistant)</h2>
        <p class="text-sm text-stone-500 mb-4">Cette valeur survit au rechargement de la page et à la fermeture du navigateur.</p>
        
        <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold text-stone-400 uppercase tracking-wider">Votre Nom</label>
            <input type="text" on:input={{ userName.Set(this.Get("value").String()) }} class="px-4 py-2 rounded-lg border border-stone-200 focus:ring-2 focus:ring-amber-500 outline-none transition" />
        </div>
        
        <p class="mt-4 text-stone-600">Bonjour, <span class="font-bold text-amber-600" bind:content={{userName.Get()}}>...</span> !</p>
    </div>

    <div class="mt-6 p-6 bg-white rounded-2xl shadow-sm border border-stone-100">
        <h2 class="text-lg font-bold text-stone-700">SessionStorage (Temporaire)</h2>
        <p class="text-sm text-stone-500 mb-4">Cette valeur est réinitialisée quand vous fermez l'onglet.</p>
        
        <div class="flex items-center gap-4">
            <button on:click={{incrementSession()}} class="px-6 py-2 bg-stone-800 text-white rounded-full font-bold hover:bg-stone-700 transition">
                Incrémenter
            </button>
            <p>Valeur : <span class="font-mono font-bold" bind:content={{sessionData.Get()}}>...</span></p>
        </div>
    </div>

    <button on:click={{clearAll()}} class="mt-8 text-sm text-red-500 hover:underline">
        Tout effacer (Local + Session)
    </button>
    
    <div class="mt-12 text-center">
        <a href="/guide" class="text-stone-400 hover:text-stone-600 transition">← Retour au Guide</a>
    </div>
</div>
